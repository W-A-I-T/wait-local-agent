# WAIT Local Agent configuration reference.
# Copy this file to `.env`, then fill in only the values you need.
# Leave secret values blank here.

# SQLite state file for the local appliance or host-side CLI.
WAIT_DATA_PATH=.wait-local-agent/state.db

# Root directory allowed for knowledge ingest paths.
WAIT_ALLOWED_DOC_ROOT=examples/sample_docs

# Legacy admin-equivalent bearer token.
WAIT_API_TOKEN=

# Preferred role-scoped bearer tokens.
WAIT_ADMIN_TOKEN=
WAIT_TECH_TOKEN=
WAIT_VIEWER_TOKEN=

# Local demo mode bypasses bearer auth when enabled.
WAIT_DEMO_MODE=true

# Secret backend: `env` or `fernet`.
WAIT_SECRETS_BACKEND=env

# Fernet vault directory used for stored secrets and encrypted backup keys.
WAIT_VAULT_PATH=.wait-local-agent/vault

# Enables live connector write execution after approval.
WAIT_ALLOW_WRITE_ACTIONS=false

# Enables outbound HTTP calls for HaloPSA and Hudu.
WAIT_ALLOW_HTTP_PROBING=false

# Enables provider-level cloud fallbacks when supported.
WAIT_ALLOW_CLOUD_FALLBACK=false

# Enables local LLM inference through the configured provider endpoint.
WAIT_ALLOW_LLM_INFERENCE=false

# Chat-completions provider used for optional local inference.
WAIT_LOCAL_MODEL_PROVIDER=deterministic

# Base URL for the OpenAI-compatible local model endpoint.
WAIT_LOCAL_MODEL_BASE_URL=http://127.0.0.1:11434/v1

# Model name passed to the local model provider.
WAIT_LOCAL_MODEL_NAME=llama3.1

# Timeout, in seconds, for local model requests.
WAIT_LOCAL_MODEL_TIMEOUT_SECONDS=20

# Search backend: `sqlite` or `qdrant`.
WAIT_VECTOR_BACKEND=sqlite

# Knowledge parser mode.
WAIT_DOCUMENT_PARSER=basic

# Enables OCR when the optional parser stack is installed.
WAIT_ALLOW_OCR=false

# Embedding provider used by the vector backend.
WAIT_EMBEDDING_PROVIDER=none

# Embedding model name for vector indexing.
WAIT_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Local embedded Qdrant path when using the qdrant backend.
WAIT_QDRANT_PATH=.wait-local-agent/qdrant

# Remote Qdrant URL when using an external Qdrant service.
WAIT_QDRANT_URL=

# Qdrant collection name.
WAIT_QDRANT_COLLECTION=wait_knowledge_chunks

# Timeout, in seconds, for connector HTTP operations.
WAIT_CONNECTOR_TIMEOUT_SECONDS=20

# Enables the APScheduler-backed scheduled workflow runner.
WAIT_SCHEDULER_ENABLED=true

# Enables FastAPI rate limiting.
WAIT_RATE_LIMIT_ENABLED=true

# Default per-route rate limit.
WAIT_RATE_LIMIT_GENERAL=100/minute

# Tighter limit for connector and approval-execution routes.
WAIT_RATE_LIMIT_CONNECTOR=10/minute

# Signed update metadata URL. Empty disables update checks.
WAIT_UPDATE_CHANNEL_URL=

# Comma-separated unpadded base64url Ed25519 public keys for update verification.
WAIT_UPDATE_PUBKEYS=

# HaloPSA base URL.
WAIT_HALOPSA_BASE_URL=

# HaloPSA OAuth client id.
WAIT_HALOPSA_CLIENT_ID=

# HaloPSA OAuth client secret.
WAIT_HALOPSA_CLIENT_SECRET=

# HaloPSA tenant identifier.
WAIT_HALOPSA_TENANT=

# Optional explicit HaloPSA token endpoint.
WAIT_HALOPSA_TOKEN_URL=

# HaloPSA ticket write endpoint name.
WAIT_HALOPSA_TICKET_WRITE_ENDPOINT=Ticket

# HaloPSA action write endpoint name.
WAIT_HALOPSA_ACTION_WRITE_ENDPOINT=Actions

# Hudu base URL.
WAIT_HUDU_BASE_URL=

# Hudu API key.
WAIT_HUDU_API_KEY=

# Default Hudu page size for list calls.
WAIT_HUDU_PAGE_SIZE=25

# Primary pack license key used to unlock licensed packs.
WAIT_LICENSE_KEY=

# Optional secondary license secret for pack-specific validation flows.
WAIT_LICENSE_SECRET=

# Shared secret used to verify signed pack tarball installs.
WAIT_PACK_SIGNING_SECRET=
